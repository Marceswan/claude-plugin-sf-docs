{
  "name": "sf-docs",
  "version": "1.0.0",
  "description": "Salesforce documentation ingestion and search tool",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "sf-docs": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "setup": "npm install && npm run build",
    "postinstall": "npm exec -- playwright install chromium",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "eval:quality": "tsx evals/quality/run.ts",
    "eval:quality:verbose": "tsx evals/quality/run.ts --verbose"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "commander": "^13.0",
    "js-tiktoken": "^1.0",
    "playwright": "^1.50",
    "turndown": "^7.2",
    "vectra": "^0.9"
  },
  "devDependencies": {
    "@types/jest": "^29.5",
    "@types/node": "^22.0",
    "@types/turndown": "^5.0",
    "jest": "^29.7",
    "ts-jest": "^29.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7"
  }
}
